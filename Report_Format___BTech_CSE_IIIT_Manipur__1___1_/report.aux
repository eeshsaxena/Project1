\@writefile{lof}{\contentsline {figure}{\numberline {4.3}{\ignorespaces Property graph model for TruthfulRAG v5 (the graph-database equivalent of an ER diagram). \emph  {Top}: Schema — one node type \texttt  {:Entity} with properties \texttt  {name} and \texttt  {type}; one relationship type \texttt  {RELATED\_TO} carrying the five properties used for scoring and conflict resolution. \emph  {Bottom}: Two instance edges from the medical corpus showing the conflicting aspirin facts that the v5 conflict resolver must adjudicate.}}{17}{figure.caption.13}\protected@file@percent }
\newlabel{fig:pgm}{{4.3}{17}{Property graph model for TruthfulRAG v5 (the graph-database equivalent of an ER diagram). \emph {Top}: Schema — one node type \texttt {:Entity} with properties \texttt {name} and \texttt {type}; one relationship type \texttt {RELATED\_TO} carrying the five properties used for scoring and conflict resolution. \emph {Bottom}: Two instance edges from the medical corpus showing the conflicting aspirin facts that the v5 conflict resolver must adjudicate}{figure.caption.13}{}}
